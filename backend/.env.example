AGENTFLOW_DATABASE_URL=postgresql+asyncpg://agentflow:agentflow@localhost:5432/agentflow
AGENTFLOW_REDIS_URL=redis://localhost:6379/0
AGENTFLOW_LOG_LEVEL=INFO
AGENTFLOW_DEFAULT_ADAPTER=echo
AGENTFLOW_OPENAI_API_KEY=
AGENTFLOW_OPENAI_BASE_URL=https://api.openai.com/v1

# Run-job queue wire protocol. Must match the Java side's AGENTFLOW_JOBS_IMPL.
# `streams` (default): at-least-once via XADD/XREADGROUP/XACK/XAUTOCLAIM.
# `list`: legacy LPUSH/BRPOP. Kept for rollback.
AGENTFLOW_REDIS_QUEUE_IMPL=streams
AGENTFLOW_JOB_STREAM_GROUP=agentflow-workers
AGENTFLOW_JOB_STREAM_CLAIM_IDLE_MS=60000
AGENTFLOW_JOB_STREAM_MAX_DELIVERIES=5

# Max run jobs executed in parallel per worker process (default 1).
AGENTFLOW_WORKER_CONCURRENCY=1
